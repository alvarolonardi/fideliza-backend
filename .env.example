# ══════════════════════════════════════════════
#  FIDELIZA — Ejemplo de variables de entorno
#  Copiá este archivo como .env y completá los valores
# ══════════════════════════════════════════════

PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

USE_SQLITE=true
SQLITE_PATH=./fideliza.db

JWT_SECRET=CAMBIAR_POR_UN_STRING_SECRETO
JWT_EXPIRES_IN=7d

# WhatsApp: false = envíos reales por Twilio
WHATSAPP_MOCK=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Número del local (Casa Sierra Gualeguaychú)
CASA_SIERRA_WHATSAPP=+5493446377495

# URL pública donde está la app (ngrok en desarrollo, dominio real en producción)
QR_BASE_URL=http://localhost:3000/registro
